[central]
# assuming the central server is local, else provide ansible_host, ansible_user & ansible_ssh_private_key_file
localhost ansible_connection=local
# central ansible_host=<SERVER_IP> ansible_ssh_private_key_file=<PATH_TO_SERVER_SSH_PRIVATE_KEY>

[docker_servers]
# docker_server1 ansible_host=<SERVER_IP> ansible_ssh_private_key_file=<PATH_TO_SERVER_SSH_PRIVATE_KEY>

[cluster_servers]
# cluster_server1 ansible_host=<SERVER_IP> ansible_ssh_private_key_file=<PATH_TO_SERVER_SSH_PRIVATE_KEY>

[all:vars]
ansible_user=root
ansible_ssh_common_args='-o IdentitiesOnly=yes'
crowdsec_server_url=http://127.0.0.1:8080
prometheus_server_url=http://127.0.0.1:9090
